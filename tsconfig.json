{
  "compilerOptions": {
    "strict": true,
    "target": "esnext",
    "noEmit": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "jsx": "preserve"
  }
}
